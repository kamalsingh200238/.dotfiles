{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "edit": "ask",
    "bash": {
      "sudo*": "deny",
      "rm*": "deny",
      "*": "ask"
    },
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": "ask"
  },
  "plugin": [
    "opencode-rules@latest"
  ],
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
  }
}
